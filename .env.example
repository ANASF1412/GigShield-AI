# JARVIS EnviroSense Assurance - Environment Variables

# ── SUPABASE (REQUIRED FOR CLOUD SYNC) ──
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_service_role_key_here

# ── FALLBACK SETTINGS ──
# Set to 'false' to force the system to use offline cache mode during demonstrations
USE_LIVE_API=true

# ── CHATBOT ASSISTANT (OPTIONAL) ──
# Remove or leave empty to default to Sandboxed Rule-Based Mode
GEMINI_API_KEY=your_gemini_api_key_here

# ── ENVIRONMENTAL APIS (OPTIONAL) ──
# If omitted, local mock environmental matrices will trigger the payload tests safely
OPENWEATHER_API_KEY=
AQI_API_KEY=
